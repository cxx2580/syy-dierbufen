<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="draw.io" version="26.0.0">
  <diagram name="采购数据流程">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 外部实体：供应商 -->
        <mxCell id="2" value="供应商" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- 外部实体：仓库管理员 -->
        <mxCell id="3" value="仓库管理员" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- 处理：采购订单管理 -->
        <mxCell id="4" value="采购订单管理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="150" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 处理：入库处理 -->
        <mxCell id="5" value="入库处理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="280" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 处理：库存更新 -->
        <mxCell id="6" value="库存更新" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="410" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- 数据存储：供应商表 -->
        <mxCell id="7" value="供应商表&#xa;(supplier)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="140" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- 数据存储：采购订单表 -->
        <mxCell id="8" value="采购订单表&#xa;(purchase_order)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="140" width="140" height="80" as="geometry" />
        </mxCell>

        <!-- 数据存储：采购明细表 -->
        <mxCell id="9" value="采购明细表&#xa;(purchase_order_item)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="260" width="140" height="80" as="geometry" />
        </mxCell>

        <!-- 数据存储：产品表 -->
        <mxCell id="10" value="产品表&#xa;(product)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="400" width="130" height="80" as="geometry" />
        </mxCell>

        <!-- ===== 数据流 ===== -->

        <!-- 供应商→采购订单管理 -->
        <mxCell id="e1" value="供应商信息" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="2" target="4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 仓库管理员→入库处理 -->
        <mxCell id="e2" value="入库确认" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="3" target="5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 采购订单管理→入库处理 -->
        <mxCell id="e3" value="已审核订单" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="4" target="5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 入库处理→库存更新 -->
        <mxCell id="e4" value="入库数量" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 采购订单管理→供应商表 -->
        <mxCell id="e5" value="查询/写入" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="4" target="7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 采购订单管理→采购订单表 -->
        <mxCell id="e6" value="写入订单" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="4" target="8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 采购订单管理→采购明细表 -->
        <mxCell id="e7" value="写入明细" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="4" target="9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 入库处理→采购订单表 -->
        <mxCell id="e8" value="更新状态" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="5" target="8">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="480" y="310" />
              <mxPoint x="480" y="180" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 库存更新→产品表 -->
        <mxCell id="e9" value="更新库存" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=11;" edge="1" parent="1" source="6" target="10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
