<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.PurchaseOrderItemMapper">
    <resultMap id="BaseResultMap" type="com.erp.entity.PurchaseOrderItem">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="product_id" property="productId"/>
        <result column="product_name" property="productName"/>
        <result column="specification" property="specification"/>
        <result column="unit" property="unit"/>
        <result column="price" property="price"/>
        <result column="quantity" property="quantity"/>
        <result column="subtotal" property="subtotal"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.erp.entity.PurchaseOrderItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO purchase_order_item (order_id, product_id, product_name, specification, unit, price, quantity, subtotal, create_time)
        VALUES (#{orderId}, #{productId}, #{productName}, #{specification}, #{unit}, #{price}, #{quantity}, #{subtotal}, NOW())
    </insert>

    <delete id="deleteByOrderId">
        DELETE FROM purchase_order_item WHERE order_id = #{orderId}
    </delete>

    <select id="selectByOrderId" resultMap="BaseResultMap">
        SELECT * FROM purchase_order_item WHERE order_id = #{orderId}
    </select>
</mapper>
