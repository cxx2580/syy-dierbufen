<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.CustomerMapper">
    <resultMap id="BaseResultMap" type="com.erp.entity.Customer">
        <id column="id" property="id"/>
        <result column="customer_no" property="customerNo"/>
        <result column="customer_name" property="customerName"/>
        <result column="contact" property="contact"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="address" property="address"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.erp.entity.Customer" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO customer (customer_no, customer_name, contact, phone, email, address, status, create_time, update_time)
        VALUES (#{customerNo}, #{customerName}, #{contact}, #{phone}, #{email}, #{address}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.erp.entity.Customer">
        UPDATE customer
        SET customer_name = #{customerName},
            contact = #{contact},
            phone = #{phone},
            email = #{email},
            address = #{address},
            status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM customer WHERE id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM customer WHERE id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM customer
        <where>
            <if test="customerName != null and customerName != ''">
                AND customer_name LIKE CONCAT('%', #{customerName}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="count" resultType="int">
        SELECT COUNT(*) FROM customer
        <where>
            <if test="customerName != null and customerName != ''">
                AND customer_name LIKE CONCAT('%', #{customerName}, '%')
            </if>
        </where>
    </select>
</mapper>
